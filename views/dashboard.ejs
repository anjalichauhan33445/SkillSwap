<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Dashboard - SkillSwap</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="bg-white min-h-screen px-6 py-10">
    <!-- <div class="absolute w-96 h-96 bg-pink-300 opacity-30 rounded-full -top-20 -left-20 animate-pulse"></div>
    <div class="absolute w-80 h-80 bg-blue-300 opacity-30 rounded-full -bottom-20 -right-10 animate-bounce"></div>
    <div class="absolute w-72 h-72 bg-purple-300 opacity-20 rounded-full top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2 blur-2xl"></div> -->
    <svg class="absolute top-10 left-10 w-20 h-20 opacity-20 -z-10" viewBox="0 0 24 24" fill="#60a5fa" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2a7 7 0 00-7 7c0 2.386 1.08 4.007 2.132 5.209.638.734.868 1.558.868 2.291V17a1 1 0 001 1h6a1 1 0 001-1v-.5c0-.733.23-1.557.868-2.291C17.92 13.007 19 11.386 19 9a7 7 0 00-7-7z"/>
    </svg>

    <svg class="absolute bottom-10 right-10 w-24 h-24 opacity-20 -z-10" viewBox="0 0 24 24" fill="#f87171" xmlns="http://www.w3.org/2000/svg">
      <path d="M20.7 18.3l-5-5c.4-1 .3-2.1-.3-2.9l-2.5 2.5-3.5-3.5 2.5-2.5c-.8-.6-1.9-.7-2.9-.3l-5-5L2.3 4.3l5 5c-.4 1-.3 2.1.3 2.9l2.5-2.5 3.5 3.5-2.5 2.5c.8.6 1.9.7 2.9.3l5 5 1.4-1.4z"/>
    </svg>

    <svg class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-40 h-40 opacity-10 -z-10" viewBox="0 0 24 24" fill="#a78bfa" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 3h14a1 1 0 011 1v15.5a.5.5 0 01-.8.4L12 16.4l-6.2 3.5a.5.5 0 01-.8-.4V4a1 1 0 011-1z"/>
    </svg>
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold text-indigo-700 mb-4">
        Welcome, <%= user.name %> 👋
      </h1>
      <p class="text-gray-600 mb-8">
        You're skilled in <span class="font-semibold text-indigo-600"><%= user.skill %></span>
      </p>

      <!-- 🔹 Beautiful static cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <div class="p-6 bg-indigo-100 rounded-lg shadow-md">
          <h2 class="text-xl font-semibold text-indigo-700">Explore Users</h2>
          <p class="text-gray-600 mt-2">Connect and collaborate with talented peers!</p>
        </div>

        <div class="p-6 bg-pink-100 rounded-lg shadow-md">
          <h2 class="text-xl font-semibold text-pink-700">Post Your Skill</h2>
          <p class="text-gray-600 mt-2">Let others know what you can teach or mentor in!</p>
        </div>
      </div>

   
      <% if (others.length > 0) { %>
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">Other Swappers</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% others.forEach(u => { %>
            <div class="p-6 bg-gradient-to-br from-yellow-100 to-blue-100 rounded-lg shadow-md hover:shadow-lg transition">
              <h3 class="text-xl font-bold text-indigo-800"><%= u.name %></h3>
              <p class="text-gray-700 mt-1">Skill: <span class="font-semibold"><%= u.skill %></span></p>
              <p class="text-gray-500 text-sm mt-2"><%= u.email %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-gray-500 mt-4 italic">No other users found yet. Be the first to post!</p>
      <% } %>
    </div>
  </body>
</html>
